---
const year = new Date().getFullYear();
---

<footer style="border-top: 1px solid var(--border); margin-top: 4rem; padding: 2rem 1.25rem;">
  <div style="max-width: 900px; margin: 0 auto;">

    <div style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1rem;">

      <div style="display: flex; flex-wrap: wrap; gap: 1.25rem; font-size: 0.85rem;">
        <a href="/yasal-uyari/" style="color: var(--text-muted); text-decoration: none;">Yasal Uyarı</a>
        <a href="/gizlilik-politikasi/" style="color: var(--text-muted); text-decoration: none;">Gizlilik Politikası</a>
        <a href="/rss.xml" style="color: var(--text-muted); text-decoration: none;" title="RSS Feed">RSS</a>
      </div>

      <p style="font-size: 0.82rem; color: var(--text-muted); margin: 0;">
        © {year} Yatırım Notları
      </p>

    </div>

    <p style="font-size: 0.78rem; color: var(--text-muted); margin-top: 1rem; margin-bottom: 0; line-height: 1.5;">
      Bu sitedeki yazılar yalnızca bilgi amaçlıdır ve yatırım tavsiyesi niteliği taşımaz.
    </p>

  </div>
</footer>
